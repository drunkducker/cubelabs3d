# Cube Labs Supabase project configuration.
# Add these same variables in Vercel under Project Settings > Environment Variables.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Canonical site origin for Supabase email links (password reset, signup
# confirmation). Optional: if unset, the app uses the current request origin,
# then falls back to the production URL. Set this to pin all email links to one
# domain. Whatever origin is used must be listed in Supabase Auth > URL
# Configuration > Redirect URLs.
NEXT_PUBLIC_SITE_URL=https://cubelabs3d.vercel.app

# Admin portal owner failsafe. This account is always treated as the Owner
# (full admin access), even before the role bootstrap row is applied. Server-
# side only — do NOT prefix with NEXT_PUBLIC. Set in Vercel Project Settings.
ADMIN_OWNER_EMAIL=dleshrader@gmail.com

# Active data provider (portability seam). Default: supabase. Switching this to
# another registered provider in app/lib/data swaps the backend with no feature
# code changes. See docs/PORTABILITY-AND-EXIT.md.
DATA_PROVIDER=supabase

# Cube Labs Supabase project configuration.
# Add these same variables in Vercel under Project Settings > Environment Variables.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# --- Admin platform (SERVER-ONLY — never prefix with NEXT_PUBLIC_) ---
# The service-role key bypasses RLS and is used only in server code AFTER an
# administrator passes authentication + permission checks. Never expose it to
# the browser. SUPABASE_URL falls back to NEXT_PUBLIC_SUPABASE_URL if unset.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# After creating the first owner account, bootstrap it once in the Supabase SQL
# editor:  select public.bootstrap_owner('you@example.com');

# Canonical site origin for Supabase email links (password reset, signup
# confirmation). Optional: if unset, the app uses the current request origin,
# then falls back to the production URL. Set this to pin all email links to one
# domain. Whatever origin is used must be listed in Supabase Auth > URL
# Configuration > Redirect URLs.
NEXT_PUBLIC_SITE_URL=https://cubelabs3d.vercel.app
